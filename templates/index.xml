                                <!--                                    <div class="top-area">-->
                                <!--                                        <div class="top">-->
                                <!--                                            <img class="default-img"-->
                                <!--                                                 src="https://timeaccess-store.com/cdn/shop/files/SPB473J1-G.jpg?v=1781940506&amp;width=1000"-->
                                <!--                                                 alt=""/>-->
                                <!--                                            <img class="hover-img"-->
                                <!--                                                 src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=400&amp;q=80"-->
                                <!--                                                 alt=""/>-->
                                <!--                                        </div>-->
