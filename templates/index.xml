<odoo>
    <template id="index_page">
        <t t-call="time_access_portal.custom_layout">

            <!--===========================================================-->
            <!--================||  Filter Section Here  ||=============== -->
            <!--===========================================================-->
            <section class="filter-sec mt-7">
                <div class="container">
                    <div class="filter-sec-wrap">

                        <div class="category-buttons d-flex gap-3 flex-wrap" id="categoryContainer">

                            <!-- All Categories default active -->
                            <a t-att-href="'/index?sort=%s' % sort"
                               t-att-class="'cart-btn active' if not selected_category_id else 'cart-btn'">
                                All Categories
                            </a>

                            <!-- Only child categories (parent_id != False) -->
                            <t t-foreach="categories" t-as="category">
                                <t t-if="category.parent_id">
                                    <a t-att-href="'/index?category_id=%s&amp;sort=%s' % (category.id, sort)"
                                       t-att-class="'cart-btn active' if selected_category_id == category.id else 'cart-btn'">
                                        <t t-esc="category.name"/>
                                    </a>
                                </t>
                            </t>

                        </div>

                        <div class="search-sort-bar mt-6 flex-between flex-wrap gap-sm-4 gap-7">

                            <!-- Search Input Here -->
                            <div class="search-box input-group">
                                <input type="text" class="search-input" id="searchInput" oninput="searchProducts()"
                                       placeholder="Search by Product Name or Item ID "/>
                                <div class="search-icon-below">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                         fill="none" stroke="#888" stroke-width="2" stroke-linecap="round"
                                         stroke-linejoin="round">
                                        <circle cx="11" cy="11" r="8"/>
                                        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                                    </svg>
                                </div>
                            </div>

                            <div class="filter-options d-flex gap-6">
                                <div>
                                    <select id="sortSelect" onchange="window.location.href='index?sort=' + this.value">
                                        <option value="default"
                                                t-att-selected="'selected' if sort== 'default' else None">Default
                                            Sorting
                                        </option>
                                        <option value="low-high"
                                                t-att-selected="'selected' if sort == 'low-high' else None">Price: Low
                                            to High
                                        </option>
                                        <option value="high-low"
                                                t-att-selected="'selected' if sort == 'high-low' else None">Price: High
                                            to Low
                                        </option>
                                    </select>
                                </div>


                                <!-- Grid and List View  -->
                                <div class="view-toggle d-flex gap-1">

                                    <!-- Grid View -->
                                    <button class="flex-center active" id="gridBtn" type="button"
                                            aria-label="Grid View">
                                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <!-- Top Left -->
                                            <rect x="3.5" y="3.5" width="7" height="7" rx="2" stroke="currentColor"
                                                  stroke-width="1.6" stroke-linejoin="round"/>
                                            <!-- Top Right -->
                                            <rect x="13.5" y="3.5" width="7" height="7" rx="2" stroke="currentColor"
                                                  stroke-width="1.6" stroke-linejoin="round"/>
                                            <!-- Bottom Left -->
                                            <rect x="3.5" y="13.5" width="7" height="7" rx="2" stroke="currentColor"
                                                  stroke-width="1.6" stroke-linejoin="round"/>
                                            <!-- Bottom Right -->
                                            <rect x="13.5" y="13.5" width="7" height="7" rx="2" stroke="currentColor"
                                                  stroke-width="1.6" stroke-linejoin="round"/>
                                        </svg>

                                    </button>

                                    <!-- List view -->
                                    <button class="flex-center" id="listBtn" type="button" aria-label="List View">
                                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <!-- Row 1 -->
                                            <rect x="3.5" y="4" width="4" height="4" rx="1.2" stroke="currentColor"
                                                  stroke-width="1.6" stroke-linejoin="round"/>
                                            <path d="M11 5H20.5" stroke="currentColor" stroke-width="1.6"
                                                  stroke-linecap="round"/>

                                            <!-- Row 2 -->
                                            <rect x="3.5" y="10" width="4" height="4" rx="1.2" stroke="currentColor"
                                                  stroke-width="1.6" stroke-linejoin="round"/>
                                            <path d="M11 11H20.5" stroke="currentColor" stroke-width="1.6"
                                                  stroke-linecap="round"/>

                                            <!-- Row 3 -->
                                            <rect x="3.5" y="16" width="4" height="4" rx="1.2" stroke="currentColor"
                                                  stroke-width="1.6" stroke-linejoin="round"/>
                                            <path d="M11 17H17.5" stroke="currentColor" stroke-width="1.6"
                                                  stroke-linecap="round" opacity="0.8"/>
                                        </svg>

                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>


            <!--============================================================-->
            <!--================||  Product Section Here  ||=============== -->
            <!--============================================================-->
            <section class="product-sec">
                <div class="container">
                    <div class="product-sec-wrap">

                        <div class="contents">
                            <!--===================================||  Grid View Products Here  ||====================================-->
                            <div class="content  grid-5 grid-lg-4 grid-sm-2 gap-sm-3 gap-lg-4 gap-6"
                                 id="grid-list-contents">

                                <t t-foreach="products" t-as="product">
                                    <div class="product-card"
                                         t-att-data-name="product.name or ''"
                                         t-att-data-item-id="product.default_code or product.id">

                                        <!-- cart tag -->
                                        <div class="tag-badge">hot seller</div>

                                        <!--===== Product Images =====-->
                                        <div class="top-area">
                                            <div class="top">
                                                <t t-if="product.image_1920">
                                                    <img class="default-img"
                                                         t-att-src="image_data_uri(product.image_1920)"
                                                         alt="product image"/>
                                                </t>
                                                <t t-else="">
                                                    <img class="default-img"
                                                         src="/web/static/img/placeholder.png"
                                                         alt="product image"/>
                                                </t>
                                                <!--                                            <img class="hover-img"-->
                                                <!--                                                 src="https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=400&amp;q=80"-->
                                                <!--                                                 alt=""/>-->
                                            </div>
                                        </div>

                                        <!--===== Product Content ====-->
                                        <div class="product-content">
                                            <div>
                                                <!-- product id -->
                                                <div class="product-id fs-xs">Item ID:
                                                    <span t-esc="product.default_code"></span>
                                                </div>

                                                <!-- product name -->
                                                <a href="#" class="product-name" t-esc="product.name">UltraHD
                                                    4K Display Panels (Wholesale) Display New
                                                </a>

                                                <!-- price -->
                                                <div class="price d-flex align-center gap-4 mt-1 gap-sm-2">
                                                    <div class="new-price fs-md">TK
                                                        <span t-esc="product.list_price">1200.00</span>
                                                    </div>
                                                    <div class="old-price">TK
                                                        <span>1340.00</span>
                                                    </div>
                                                </div>
                                            </div>


                                            <div class="qty-btns">
                                                <!-- quantity input -->
                                                <div class="qty-wrapper d-flex align-center mt-3 gap-2">
                                                    <label class="">Quantity:</label>
                                                    <input type="number" class="qty-input" id="qty-PROD-101" value="5"
                                                           min="5"/>
                                                </div>

                                                <!-- Card Buttons -->
                                                <div class="card-actions grid-2 gap-3 mt-4 grid-sm-1">
                                                    <button class="btn add_to_cart btn-outline">Add
                                                        to Cart
                                                    </button>
                                                    <a href="/cart.html" class="btn btn-primary"
                                                       onclick="addToCart('PROD-101', true)">Buy
                                                        Now
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </t>

                                <!--================= single product card ===============-->
