<odoo>
    <template id="index_page">
        <t t-call="time_access_portal.custom_layout">

            <!--===========================================================-->
            <!--================||  Filter Section Here  ||=============== -->
            <!--===========================================================-->
            <section class="filter-sec mt-7">
                <div class="container">
                    <div class="filter-sec-wrap">

                        <div class="category-buttons d-flex gap-3 flex-wrap" id="categoryContainer">

                            <!-- All Categories -->
                            <a t-att-href="'/index?sort=%s' % sort"
                               t-att-class="'cart-btn active' if not selected_category_id else 'cart-btn'">
                                All Categories
                            </a>

                            <!-- Child categories -->
                            <t t-foreach="categories" t-as="category">
                                <t t-if="category.parent_id">
                                    <a t-att-href="'/index?category_id=%s&amp;sort=%s' % (category.id, sort)"
                                       t-att-class="'cart-btn active' if selected_category_id == category.id else 'cart-btn'">
                                        <t t-esc="category.name"/>
                                    </a>
                                </t>
                            </t>

                        </div>

                        <div class="search-sort-bar mt-6 flex-between flex-wrap gap-sm-4 gap-7">

                            <!-- Search Input Here -->
                            <div class="search-box input-group">
                                <input type="text" class="search-input" id="searchInput" oninput="searchProducts()"
                                       placeholder="Search by Product Name or Item ID "/>
                                <div class="search-icon-below">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                         fill="none" stroke="#888" stroke-width="2" stroke-linecap="round"
                                         stroke-linejoin="round">
                                        <circle cx="11" cy="11" r="8"/>
                                        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                                    </svg>
                                </div>
                            </div>

                            <div class="filter-options d-flex gap-6">
                                <!-- Sort select -->
                                <select id="sortSelect">
                                    <option value="default"
                                            t-att-selected="'selected' if sort == 'default' else None">Default
                                        Sorting
                                    </option>
                                    <option value="low-high"
                                            t-att-selected="'selected' if sort == 'low-high' else None">Price: Low
                                        to High
                                    </option>
                                    <option value="high-low"
                                            t-att-selected="'selected' if sort == 'high-low' else None">Price: High
                                        to Low
                                    </option>
                                </select>


                                <!-- Grid and List View  -->
                                <div class="view-toggle d-flex gap-1">

                                    <!-- Grid View -->
                                    <button class="flex-center active" id="gridBtn" type="button"
                                            aria-label="Grid View">
                                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <!-- Top Left -->
                                            <rect x="3.5" y="3.5" width="7" height="7" rx="2" stroke="currentColor"
                                                  stroke-width="1.6" stroke-linejoin="round"/>
                                            <!-- Top Right -->
                                            <rect x="13.5" y="3.5" width="7" height="7" rx="2" stroke="currentColor"
                                                  stroke-width="1.6" stroke-linejoin="round"/>
                                            <!-- Bottom Left -->
                                            <rect x="3.5" y="13.5" width="7" height="7" rx="2" stroke="currentColor"
                                                  stroke-width="1.6" stroke-linejoin="round"/>
                                            <!-- Bottom Right -->
                                            <rect x="13.5" y="13.5" width="7" height="7" rx="2" stroke="currentColor"
                                                  stroke-width="1.6" stroke-linejoin="round"/>
                                        </svg>

                                    </button>

                                    <!-- List view -->
                                    <button class="flex-center" id="listBtn" type="button" aria-label="List View">
                                        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                            <!-- Row 1 -->
                                            <rect x="3.5" y="4" width="4" height="4" rx="1.2" stroke="currentColor"
                                                  stroke-width="1.6" stroke-linejoin="round"/>
                                            <path d="M11 5H20.5" stroke="currentColor" stroke-width="1.6"
                                                  stroke-linecap="round"/>

                                            <!-- Row 2 -->
                                            <rect x="3.5" y="10" width="4" height="4" rx="1.2" stroke="currentColor"
                                                  stroke-width="1.6" stroke-linejoin="round"/>
                                            <path d="M11 11H20.5" stroke="currentColor" stroke-width="1.6"
                                                  stroke-linecap="round"/>

                                            <!-- Row 3 -->
                                            <rect x="3.5" y="16" width="4" height="4" rx="1.2" stroke="currentColor"
                                                  stroke-width="1.6" stroke-linejoin="round"/>
                                            <path d="M11 17H17.5" stroke="currentColor" stroke-width="1.6"
                                                  stroke-linecap="round" opacity="0.8"/>
                                        </svg>

                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>


            <!--============================================================-->
            <!--================||  Product Section Here  ||=============== -->
            <!--============================================================-->
            <section class="product-sec">
                <div class="container">
                    <div class="product-sec-wrap">

                        <div class="contents">
                            <!--===================================||  Grid View Products Here  ||====================================-->
                            <div class="content  grid-5 grid-lg-4 grid-sm-2 gap-sm-3 gap-lg-4 gap-6"
                                 id="grid-list-contents">

                                <t t-foreach="products" t-as="product">
                                    <t t-set="variant" t-value="product.product_variant_id"/>

                                    <div class="product-card"
                                         t-att-data-name="product.name or ''"
                                         t-att-data-item-id="product.default_code or product.id">

                                        <!-- cart tag -->
                                        <t t-if="product.product_tag_ids">
                                            <t t-foreach="product.product_tag_ids" t-as="tag">
                                                <div class="tag-badge" t-esc="tag.name"/>
                                            </t>
                                        </t>

                                        <!--===== Product Images =====-->
                                        <div class="top-area">
                                            <div class="top">
                                                <t t-if="product.image_1920">
                                                    <img class="default-img"
                                                         t-att-src="image_data_uri(product.image_1920)"
                                                         alt="product image"/>
                                                </t>
                                                <t t-else="">
                                                    <img class="default-img"
                                                         src="/web/static/img/placeholder.png"
                                                         alt="product image"/>
                                                </t>
                                            </div>
                                        </div>

                                        <!--===== Product Content ====-->
                                        <div class="product-content">
                                            <div>
                                                <div class="product-id fs-xs">SKU:
                                                    <span t-esc="product.default_code or ''"/>
                                                </div>

                                                <a href="#" class="product-name" t-esc="product.name"/>

                                                <!-- B2B price only for management -->
                                                <t t-if="request.env.user.has_group('time_access_portal.group_b2b_management')">
                                                    <div class="price d-flex align-center gap-4 mt-1 gap-sm-2">
                                                        <div class="new-price fs-md">TK
                                                            <span t-esc="'%.2f' % product.b2b_price"/>
                                                        </div>
                                                    </div>
                                                </t>
                                            </div>

                                            <div class="qty-btns">
                                                <div class="d-flex align-center gap-4">
                                                    <div class="qty-wrapper d-flex align-center mt-3 gap-2">
                                                        <label>Quantity:</label>
                                                        <input type="number"
                                                               class="qty-input"
                                                               t-att-id="'qty-%s' % variant.id"
                                                               t-att-value="2 if variant.qty_available >= 2 else int(variant.qty_available)"
                                                               min="2"
                                                               t-att-max="int(variant.qty_available)"
                                                               t-att-data-stock="int(variant.qty_available)"
                                                               t-att-disabled="variant.qty_available &lt; 2"/>
                                                    </div>

                                                    <div class="mt-2">
                                                        <span>Stock:</span>
                                                        <span class="fw-bold"
                                                              t-field="product.qty_available"
                                                              t-options="{'widget': 'float', 'precision': 0}"/>
                                                    </div>
                                                </div>


                                                <!-- quantity validation sms here -->
                                               <div class="error-text mt-3 px-2 p-2 radius-sm fw-medium fs-xs"
                                                 style="background:red;color:#f2f2f2; display:none;">
                                            </div>

                                                <div class="card-actions grid-2 gap-3 mt-4 grid-sm-1">

                                                    <!-- Add to Cart Button -->
                                                    <t t-if="variant.id in cart_product_ids">
                                                        <button class="btn add_to_cart btn-outline disabled"
                                                                t-att-data-product-id="variant.id"
                                                                disabled="disabled"
                                                                title="Already added to cart">
                                                            Added to Cart
                                                        </button>
                                                    </t>

                                                    <t t-else="">
                                                        <button class="btn add_to_cart btn-outline"
                                                                t-att-data-product-id="variant.id">
                                                            Add to Cart
                                                        </button>
                                                    </t>

                                                    <!-- Buy Now Button -->
                                                    <a href="#"
                                                       class="btn btn-primary btn-buy-now"
                                                       t-att-data-product-id="variant.id">
                                                        Buy Now
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </t>
                            </div>


                            <!--============== Pagination (per page at least 30 item show)=============-->
                            <!-- Pagination  template call-->
                            <t t-call="time_access_portal.reusable_pagination"/>
                        </div>

                        <!--===================  When Search Result Not Match  ====================-->
                        <div class="no-results-container" id="noResultsBox" style="display: none;">
                            <div class="no-results-icon">
                                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path
                                            d="M11 19C15.4183 19 19 15.4183 19 11C19 6.58172 15.4183 3 11 3C6.58172 3 3 6.58172 3 11C3 15.4183 6.58172 19 11 19Z"
                                            stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                                            stroke-linejoin="round"/>
                                    <path d="M21 21L16.65 16.65" stroke="currentColor" stroke-width="1.5"
                                          stroke-linecap="round" stroke-linejoin="round"/>
                                    <path d="M9 9L13 13" stroke="currentColor" stroke-width="1.5"
                                          stroke-linecap="round"/>
                                    <path d="M13 9L9 13" stroke="currentColor" stroke-width="1.5"
                                          stroke-linecap="round"/>
                                </svg>
                            </div>
                            <h3 class="no-results-title">No Matching Products Found</h3>
                            <p class="no-results-text">We couldn't find any items matching your search. Please check
                                the
                                spelling or try searching with a different product name or Item ID (e.g., PROD-105).
                            </p>

                            <button type="button" class="btn-clear-search" onclick="location.reload();">
                                Clear Search &amp;amp; View All
                            </button>
                        </div>
                    </div>

                </div>
            </section>


            <!-- Add To Cart Popup -->
            <div id="b2bCartPopup" class="b2b-cart-popup ">
                <div class="b2b-cart-popup-box">
                    <div class="b2b-cart-popup-icon" id="b2bCartPopupIcon">
                        ✓
                    </div>

                    <div class="b2b-cart-popup-content">
                        <h4 id="b2bCartPopupTitle">Added to Cart</h4>
                        <p id="b2bCartPopupMessage">Product added to draft order successfully.</p>
                    </div>
                </div>
            </div>


            <script src="/time_access_portal/static/src/js/home.js?v=2"></script>
            <script src="/time_access_portal/static/src/js/cart.js?v=2"></script>
        </t>
    </template>
</odoo>