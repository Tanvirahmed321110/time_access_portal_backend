                                <!--                                    <div class="product-content">-->
                                <!--                                        <div>-->
                                <!--                                            &lt;!&ndash; product id &ndash;&gt;-->
                                <!--                                            <div class="product-id fs-xs">Item ID: PROD-105</div>-->

                                <!--                                            &lt;!&ndash; product name &ndash;&gt;-->
                                <!--                                            <a href="#" class="product-name" onclick="viewDetails('PROD-105')">UltraHD-->
                                <!--                                                4K Display Panels (Wholesale) Display New-->
                                <!--                                            </a>-->

                                <!--                                            &lt;!&ndash; price &ndash;&gt;-->
                                <!--                                            <div class="price d-flex align-center gap-4 mt-1 gap-sm-2">-->
                                <!--                                                <div class="new-price fs-md">TK-->
                                <!--                                                    <span>1200.00</span>-->
                                <!--                                                </div>-->
                                <!--                                                <div class="old-price">TK-->
                                <!--                                                    <span>1340.00</span>-->
