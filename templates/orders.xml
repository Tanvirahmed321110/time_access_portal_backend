<odoo>
    <template id="orders_page">
        <t t-call="time_access_portal.custom_layout">

            <link rel="stylesheet" href="/time_access_portal/static/src/css/cart-checkout.css?v=1"/>


            <!--============================================================-->
            <!--================||  Orders Section Here   ||=============== -->
            <!--============================================================-->
            <section class="order-sec my-7">
                <div class="container">

                    <h2 class="page-title">ALl Orders</h2>

                    <div class="orders mt-5">
                        <t t-if="orders">
                            <div class="orders-card-grid grid-5 gap-5 grid-lg-4 grid-md-2 gap-md-2"
                                 style=" margin-top: 24px;">

                                <t t-foreach="orders" t-as="order">
                                    <div class="order-item-card"
                                         style="background: #ffffff; border: 1px solid #e2e8f0; border-radius: 16px; padding: 16px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05); display: flex; flex-direction: column; justify-content: space-between; transition: transform 0.2s ease;">

                                        <div>
                                            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px;">
                                                <span style="font-size: 18px; font-weight: 700; color: #1e293b;">
                                                    <t t-esc="order.name"/>
                                                </span>
                                                <div>
                                                    <t t-set="delivery_pickings"
                                                       t-value="order.picking_ids.filtered(lambda p: p.state != 'cancel')"/>

                                                    <!-- Quotation / Draft -->
                                                    <t t-if="order.state in ['draft', 'sent']">
                                                        <span class="badge pending">Pending</span>
                                                    </t>

                                                    <!-- Cancelled -->
                                                    <t t-elif="order.state == 'cancel'">
                                                        <span class="badge cancel">Canceled</span>
                                                    </t>

                                                    <!-- Delivered: all delivery orders are done -->
                                                    <t t-elif="delivery_pickings and not delivery_pickings.filtered(lambda p: p.state != 'done')">
                                                        <span class="badge success">Delivered</span>
                                                    </t>

                                                    <!-- Confirmed sale order but not fully delivered -->
                                                    <t t-elif="order.state == 'sale'">
                                                        <span class="badge processing">Processing</span>
                                                    </t>

                                                    <!-- Locked / Done Sale Order -->
                                                    <t t-elif="order.state == 'done'">
                                                        <span class="badge success">Completed</span>
                                                    </t>

                                                    <!-- Fallback -->
                                                    <t t-else="">
                                                        <span class="badge pending">Pending</span>
                                                    </t>
                                                </div>
                                            </div>

                                            <div style="font-size: 14px; color: #64748b; margin-bottom: 16px; display: flex; align-items: center; gap: 6px;">
                                                <i class="fa fa-calendar"></i>
                                                <t t-esc="order.date_order.strftime('%B %d, %Y') if order.date_order else ''"/>
                                            </div>

                                            <hr style="border: 0; border-top: 1px solid #f1f5f9; margin-bottom: 16px;"/>

                                            <div style="display: flex; flex-direction: column; gap: 10px; margin-bottom: 24px;">
                                                <t t-set="paid_invoices"
                                                   t-value="order.invoice_ids.filtered(lambda i: i.state == 'posted')"/>
                                                <t t-set="total_paid"
                                                   t-value="sum((inv.amount_total - inv.amount_residual) if inv.move_type == 'out_invoice' else -(inv.amount_total - inv.amount_residual) for inv in paid_invoices)"/>


                                                <div style="display: flex; justify-content: space-between; font-size: 14px; color: #64748b;">
                                                    <span>Total Amount:</span>
                                                    <span style="font-weight: 600; color: #0f172a;">TK
                                                        <t t-esc="'%.2f' % order.amount_total"/>
                                                    </span>
                                                </div>

                                                <div style="display: flex; justify-content: space-between; font-size: 14px; color: #64748b;">
                                                    <span>Total Paid:</span>
                                                    <span style="font-weight: 600; color: #16a34a;">TK
                                                        <t t-esc="'%.2f' % total_paid"/>
                                                    </span>
                                                </div>

                                                <div style="display: flex; justify-content: space-between; font-size: 15px; padding-top: 10px; border-top: 1px dashed #e2e8f0;">
                                                    <span style="font-weight: 600; color: #1e293b;">Total Due:</span>
                                                    <t t-set="total_due" t-value="order.amount_total - total_paid"/>
                                                    <t t-if="total_due &lt;= 0">
                                                        <span style="font-weight: 700; color: #16a34a;">TK 0.00</span>
                                                    </t>
                                                    <t t-else="">
                                                        <span style="font-weight: 700; color: #dc2626;">TK
                                                            <t t-esc="'%.2f' % total_due"/>
                                                        </span>
                                                    </t>
                                                </div>
                                            </div>
                                        </div>


                                        <div style="margin-top: auto;">
                                            <a t-att-href="'/orders/%s' % order.id"
                                               class="btn btn-primary btn-sm"
                                               style="display: block; text-align: center; width: 100%; padding: 11px 0; font-weight: 600; border-radius: 10px; text-decoration: none;">
                                                View Details
                                            </a>
                                        </div>

                                    </div>
                                </t>

                            </div>

                            <!-- ===== Pagination Add Kora Holo ===== -->
                            <t t-call="time_access_portal.reusable_pagination"/>
                        </t>

                        <!--=============== When Order Empty ===============-->
                        <t t-else="">
                            <div class="no-results-container">
                                <div class="no-results-icon">
                                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M11 19C15.4183 19 19 15.4183 19 11C19 6.58172 15.4183 3 11 3C6.58172 3 3 6.58172 3 11C3 15.4183 6.58172 19 11 19Z"
                                              stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                                              stroke-linejoin="round"></path>
                                        <path d="M21 21L16.65 16.65" stroke="currentColor" stroke-width="1.5"
                                              stroke-linecap="round" stroke-linejoin="round"></path>
                                        <path d="M9 9L13 13" stroke="currentColor" stroke-width="1.5"
                                              stroke-linecap="round"></path>
                                        <path d="M13 9L9 13" stroke="currentColor" stroke-width="1.5"
                                              stroke-linecap="round"></path>
                                    </svg>
                                </div>
                                <h3 class="no-results-title">You haven't placed any orders yet</h3>
                                <p class="no-results-text">It looks like you haven't made any purchases. Once you order
                                    your
                                    wholesale items, they will appear right here.
                                </p>

                                <a href="/index" type="button" class="btn-clear-search">
                                    Browse Products &amp; Shop Now
                                </a>
                            </div>
                        </t>
                    </div>
                </div>
            </section>

        </t>
    </template>
</odoo>