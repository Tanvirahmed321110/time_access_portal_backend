<odoo>
    <template id="profile_page">
        <t t-call="time_access_portal.custom_layout">

            <link rel="stylesheet" href="/time_access_portal/static/src/css/cart-checkout.css?v=1"/>


            <!--=============================================================-->
            <!--================||  Checkout Section Here  ||=============== -->
            <!--============================================================-->
            <section class="cart-page mt-7 mb-7 profile">
                <div class="container">
                    <div id="cart-page" class="page active-page">
                        <h2 class="page-title">Wholesaler Corporate Profile</h2>

                        <div class="profile-grid mt-6">

                            <!-- left side -->
                            <div class="avatar-section flex-column justify-between">
                                <div>
                                    <div class="avatar-placeholder">
                                        <svg style="opacity: .85;" viewBox="0 0 24 24"
                                             fill="none" xmlns="http://www.w3.org/2000/svg" width="44" height="44">
                                            <!-- Main Building Structure -->
                                            <path d="M2 22H22" stroke="currentColor" stroke-width="1.5"
                                                  stroke-linecap="round"/>
                                            <path d="M17 22V7C17 5.89543 16.1046 5 15 5H9C7.89543 5 7 5.89543 7 22"
                                                  stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                                                  stroke-linejoin="round"/>
                                            <path d="M7 11H17" stroke="currentColor" stroke-width="1.5"
                                                  stroke-linecap="round"/>
                                            <path d="M7 15H17" stroke="currentColor" stroke-width="1.5"
                                                  stroke-linecap="round"/>

                                            <!-- Side Buildings / Pillars -->
                                            <path d="M3 22V12C3 10.8954 3.89543 10 4.99999 10H7" stroke="currentColor"
                                                  stroke-width="1.5" stroke-linejoin="round"/>
                                            <path d="M17 10H19C20.1046 10 21 10.8954 21 12V22" stroke="currentColor"
                                                  stroke-width="1.5" stroke-linejoin="round"/>

                                            <!-- Main Entrance / Door -->
                                            <path
                                                    d="M10.5 22V19C10.5 18.1716 11.1716 17.5 12 17.5C12.8284 17.5 13.5 18.1716 13.5 19V22"
                                                    stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                                                    stroke-linejoin="round"/>
                                        </svg>
                                    </div>
                                    <h3 class="text-primary">Apex Global Trade</h3>
                                    <p style="color: var(--text-muted); font-size: 0.85rem; margin-top:5px;">Verified
                                        Tier-1
                                        Buyer
                                    </p>
                                </div>

                                <div class="">
                                    <a href="/web/session/logout?redirect=/web/login" class="btn-logout btn">
                                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                                             xmlns="http://www.w3.org/2000/svg">
                                            <path d="M15 3H6C5.44772 3 5 3.44772 5 4V20C5 20.5523 5.44772 21 6 21H15"
                                                  stroke="#ffffff" stroke-width="2" stroke-linecap="round"
                                                  stroke-linejoin="round"/>
                                            <path d="M10 12H21"
                                                  stroke="#ffffff" stroke-width="2" stroke-linecap="round"
                                                  stroke-linejoin="round"/>
                                            <path d="M17 8L21 12L17 16"
                                                  stroke="#ffffff" stroke-width="2" stroke-linecap="round"
                                                  stroke-linejoin="round"/>
                                        </svg>
                                        Logout
                                    </a>
                                </div>
                            </div>

                            <!-- right form -->
                            <div class="box-panel">
                                <h3 class="text-primary fw-bolder">Account Configuration &amp; Terms</h3>

                                <form action="/index/profile/save" method="post" class="mt-2">
                                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                    <div class="grid-2 gap-5 gap-sm-3">
                                        <div class="input-group">
                                            <label>Primary Contact Person</label>
                                            <input type="text" name="name" class="" t-att-value="partner.name or ''"/>
                                            <div class="error-message">Error Message</div>
                                        </div>
                                        <div class="input-group">
                                            <label>Corporate Email Address</label>
                                            <input type="email" name="email" t-att-value="partner.email or ''"/>
                                        </div>
                                    </div>
                                    <div class="grid-2 gap-5 gap-sm-3 mt-5">

                                        <div class="input-group">
                                            <label>Phone</label>
                                            <input type="text"
                                               name="mobile"
                                               t-att-value="partner.mobile or ''"/>
                                        </div>
                                    </div>
                                    <div class="input-group mt-5">
                                        <label for="">Address</label>
                                         <textarea name="street"><t t-esc="partner.street or ''"/></textarea>
                                    </div>

                                    <t t-if="profile_saved">
                                        <p id="profileSuccessMsg"
                                           class="note mt-5 text-success fs-md fw-bold text-right"
                                           style="color: green;">
                                            Successfully Added
                                        </p>
                                    </t>

                                    <!-- save button -->
                                    <div class="flex-end d-flex justify-end mt-6">
                                        <button type="submit" class="btn btn-primary">Save Changes</button>
                                    </div>
                                </form>

                            </div>
                        </div>
                    </div>

                </div>
            </section>

            <script>
            document.addEventListener("DOMContentLoaded", function () {
                const successMsg = document.getElementById("profileSuccessMsg");

                if (successMsg) {
                    setTimeout(function () {
                        successMsg.style.transition = "opacity 0.4s ease";
                        successMsg.style.opacity = "0";

                        setTimeout(function () {
                            successMsg.remove();
                        }, 400);
                    }, 3000);
                }
            });
        </script>
        </t>
    </template>
</odoo>