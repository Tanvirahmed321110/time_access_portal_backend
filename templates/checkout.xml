<odoo>
    <template id="checkout_page">
        <t t-call="time_access_portal.custom_layout">

            <link rel="stylesheet" href="/time_access_portal/static/src/css/cart-checkout.css?v=1"/>


            
            <!--=============================================================-->
            <!--================||  Checkout Section Here  ||=============== -->
            <!--============================================================-->
            <section class="cart-page mt-7 mb-7">
                <div class="container">
                    <div id="cart-page" class="page active-page">
                        <h2 class="page-title">Secure B2B Checkout</h2>

                        <from action="#" class="two-column-layout mt-6">
                            <div class="box-panel p-4">
                                <h4 class="fs-lg fw-bolder text-primary">Corporate Shipping &amp; Billing Information</h4>

                                <div class="flex-column gap-6 mt-5">
                                    <div class="input-group">
                                        <label for="">Company Name</label>
                                        <input type="text" placeholder="Company Name"/>
                                    </div>
                                    <div class="input-group">
                                        <label for="">Business License / BIN Number
                                        </label>
                                        <input type="text" placeholder="Business License"/>
                                    </div>
                                    <div class="input-group">
                                        <label for="">Phone
                                        </label>
                                        <input type="text" placeholder="Enter Phone"/>
                                    </div>
                                    <div class="input-group">
                                        <label for="">Email
                                        </label>
                                        <input type="text" placeholder="Enter Email"/>
                                    </div>
                                    <div class="input-group">
                                        <label for="">Shipping Warehouse Address

                                        </label>
                                        <textarea name="" id="" placeholder="Full Address..."></textarea>
                                    </div>
                                </div>



                                <div class="mt-7">
                                    <h4 class="fs-lg fw-bolder text-primary">Payment Details</h4>
                                    <div class="grid-2 gap-6 mt-3">
                                        <div class="input-group align-center gap-3">
                                            <label for="">Online Payment
                                            </label>
                                            <input type="checkbox" placeholder="Enter Email"/>
                                        </div>
                                        <div class="input-group align-center gap-3">
                                            <label for="">Cash on delivary
                                            </label>
                                            <input type="checkbox" placeholder="Enter Email"/>
                                        </div>
                                    </div>
                                </div>

                            </div>


                            <!--====================  Card Here  ==================-->
                            <div class="card-wrap radius-xl">
                                <div class="box-panel card">
                                    <h3 class="title">Final Validation</h3>
                                    <div class="flex-column gap-3 mt-5">
                                        <div class="summary-total  flex-between gap-3">
                                            <div class="fs-md fw-bold">Grand
                                                Total:</div>
                                            <div class="fs-md fw-bold" id="summaryTotal">$1250.00</div>
                                        </div>
                                    </div>

                                    <!-- Place Order Button Here -->
                                    <a href="/order_invoice.html" class="btn btn-primary btn-fs-md checkout mt-5"
                                        style="width: 100%; display: inline-flex; align-items: center; justify-content: center; gap: 10px;">
                                        <svg viewBox="0 0 24 24" width="18" fill="none"
                                            xmlns="http://www.w3.org/2000/svg" style="width: 18px; height: 18px;">
                                            <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="currentColor"
                                                stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                        </svg>
                                        Place Order
                                    </a>
                                </div>
                            </div>
                        </from>
                    </div>

                </div>
            </section>

        </t>
    </template>
</odoo>