<odoo>
    <template id="order_invoice_page">
        <t t-call="time_access_portal.custom_layout">

            <link rel="stylesheet" href="/time_access_portal/static/src/css/cart-checkout.css?v=1"/>


            <!--============================================================-->
            <!--================||  Invoice Section Here  ||=============== -->
            <!--============================================================-->
            <section class="cart-page order-confrim mt-7 mb-7">
                <div class="container">
                    <div class="confirmation-wrapper">

                        <div class="header-status">
                            <div class="success-icon-box">
                                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                    <path
                                            d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z"
                                            fill="#10B981" opacity="0.15"></path>
                                    <path d="M8 12L11 15L16 9" stroke="currentColor" stroke-width="2"
                                          stroke-linecap="round" stroke-linejoin="round"></path>
                                </svg>
                            </div>
                            <h2 class="conf-title text-primary">Order Confirmed</h2>
                            <p class="conf-subtitle fs-md">Your transaction has been securely processed and logged in
                                our
                                procurement system.
                            </p>
                        </div>

                        <div class="invoice-meta-grid">
                            <div class="meta-block">
                                <h5>Invoice ID</h5>
                                <p>#INV-2026-8942</p>
                            </div>
                            <div class="meta-block">
                                <h5>Payment Terms</h5>
                                <p>Corporate Net 30</p>
                            </div>
                            <div class="meta-block">
                                <h5>Date</h5>
                                <p>22 June 2026</p>
                            </div>
                        </div>

                        <div class="invoice-details-section">
                            <h5 class=" text-primary ps">Purchased Item Manifest</h5>

                            <table class="manifest-table mt-3">
                                <thead>
                                    <tr>
                                        <th>Product Description</th>
                                        <th style="text-align: center;">MOQ Qty</th>
                                        <th style="text-align: right;">Unit Price</th>
                                        <th style="text-align: right;">Total Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>
                                            <div class="product-info">
                                                <img src="https://images.unsplash.com/photo-1505740420928-5e560c06d30e?w=100&amp;q=80"
                                                     alt="Product Image"/>
                                                <div>
                                                    <div class="text-primary" style="font-weight: 600;">Premium
                                                        Wireless Headphones X2
                                                    </div>
                                                    <span style="font-size: 0.75rem; color: var(--text-muted);">ID:
                                                        PROD-101
                                                    </span>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-primary" style="text-align: center; font-weight: 600;">5 Lots
                                        </td>
                                        <td style="text-align: right; color: var(--text-muted);">$350.00</td>
                                        <td class="text-primary" style="text-align: right; font-weight: 600; ">
                                            $1,750.00
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <div class="product-info">
                                                <img src="https://images.unsplash.com/photo-1521572267360-ee0c2909d518?w=100&amp;q=80"
                                                     alt="Product Image"/>
                                                <div>
                                                    <div class="text-primary" style="font-weight: 600">Cotton
                                                        Crewneck T-Shirts (Pack of 50)
                                                    </div>
                                                    <span style="font-size: 0.75rem; color: var(--text-muted);">ID:
                                                        PROD-102
                                                    </span>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-primary" style="text-align: center; font-weight: 600;">2 Lots
                                        </td>
                                        <td style="text-align: right; color: var(--text-muted);">$250.00</td>
                                        <td class="text-primary" style="text-align: right; font-weight: 600; ">$500.00
                                        </td>
                                    </tr>
                                </tbody>
                            </table>

                            <div class="invoice-summary-box">
                                <div class="summary-row">
                                    <span style="color: var(--text-muted);">Corporate Subtotal:</span>
                                    <span style="font-weight: 600;">$2,250.00</span>
                                </div>
                                <div class="summary-row">
                                    <span style="color: var(--text-muted);">Est. Tax / VAT (0%):</span>
                                    <span style="font-weight: 600;">$0.00</span>
                                </div>
                                <div class="summary-row final">
                                    <span>Grand Total:</span>
                                    <span>$2,250.00</span>
                                </div>
                            </div>
                        </div>

                        <div class="btn-group">
                            <a href="index.html" class="btn btn-outline btn-fs-md" style="padding: 12px 24px;">
                                <svg width="16" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M19 12H5M5 12L12 19M5 12L12 5"></path>
                                </svg>
                                Continue Sourcing
                            </a>

                            <button class="btn btn-primary btn-fs-md" id="downloadInvoiceBtn"
                                    style="padding: 15px 24px; display: inline-flex; gap: 8px;">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                                     xmlns="http://www.w3.org/2000/svg">
                                    <path d="M12 3V16M12 16L7 11M12 16L17 11" stroke="currentColor" stroke-width="1.8"
                                          stroke-linecap="round" stroke-linejoin="round"></path>
                                    <path d="M4 20H20" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
                                    </path>
                                </svg>
                                Download Invoice Image
                            </button>
                        </div>

                    </div>
                </div>
            </section>

            <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
            <script>
                document.getElementById('downloadInvoiceBtn').addEventListener('click', function () {
                const targetSection = document.querySelector('.confirmation-wrapper');
                const btnGroup = targetSection.querySelector('.btn-group');

                const originalText = this.innerHTML;
                this.innerText = "Generating Image...";
                this.disabled = true;

                if (btnGroup) {
                btnGroup.style.display = 'none';
                }

                html2canvas(targetSection, {
                scale: 2,
                useCORS: true,
                backgroundColor: '#f9f9f9'
                }).then(canvas => {
                const imageURI = canvas.toDataURL('image/png');

                const downloadLink = document.createElement('a');
                downloadLink.href = imageURI;
                downloadLink.download = 'Invoice_INV-2026-8942.png';

                document.body.appendChild(downloadLink);
                downloadLink.click();
                document.body.removeChild(downloadLink);

                if (btnGroup) {
                btnGroup.style.display = 'flex';
                }

                this.innerHTML = originalText;
                this.disabled = false;
                }).catch(error => {
                console.error('Oops, something went wrong!', error);

                if (btnGroup) {
                btnGroup.style.display = 'flex';
                }

                this.innerHTML = originalText;
                this.disabled = false;
                });
                });
            </script>
        </t>
    </template>
</odoo>