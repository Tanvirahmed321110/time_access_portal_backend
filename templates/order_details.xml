<odoo>
    <template id="order_details_page">
        <t t-call="time_access_portal.custom_layout">

            <link rel="stylesheet" href="/time_access_portal/static/src/css/cart-checkout.css?v=1"/>


            <!--===================================================================-->
            <!--================||  Order Details Section Here   ||=============== -->
            <!--===================================================================-->
            <section class="order-sec my-7">
            <div class="container">


                <div id="order-details-section" style="max-width: 1080px; margin: 0 auto ;margin-top: 32px;">
                    <h2 class="page-title">Order Details</h2>

                    <div class="card mt-5 p-6 radius-xxl order-details-card">
                        <!-- Details Header Info -->
                        <div class="details-header flex-between">
                            <div>
                                <h5 class="fw-bolder text-primary fs-md">Order ID: #ORD-9952</h5>
                                <p class="mt-2 "> <span class="fw-bold">Placed on:</span> June 24, 2026 at
                                    4:26 PM</p>
                            </div>
                            <div class=" d-flex justify-end gap-4 flex-wrap btn-wraps gap-sm-3">
                                <a href="/index" class="btn btn-outline">Back To Home</a>
                                <button class="btn btn-primary" id="downloadInvoiceBtn">Download Invoice</button>
                            </div>
                        </div>

                        <!-- Shipping and Wholesaler Info Grid -->
                        <div class="grid-3 mt-7 gap-3 grid-sm-1">
                            <div class="info-box">
                                <h5 class="text-primary mb-2 fw-bolder">Shipping Address</h5>
                                <p>Gulshan-2, Dhaka<br/>Dhaka Division, 1212<br/>Bangladesh</p>
                            </div>
                            <div class="info-box">
                                <h5 class="text-primary mb-2 fw-bolder">Payment Method</h5>
                                <p>Bank Transfer<br/>Status: <span class="badge success ">Paid</span></p>
                            </div>
                            <div class="info-box">
                                <h5 class="text-primary mb-2 fw-bolder">Fulfillment Status</h5>
                                <p>Status: <span
                                        style="color: var(--badge-pending); font-weight: 600;"><span class="badge success  ">Processing</span> </span><br/>Expected
                                    Delivery: June 28, 2026</p>
                            </div>
                        </div>

                        <!-- Ordered Items Table -->
                        <div class="table-responsive order-confrim mt-7 w-100-p">
                            <table class="manifest-table" style="width: 100%;">
                                <thead>
                                    <tr>
                                        <th  style="min-width: 200px;width: 200px;">Product Details</th>
                                        <th>Item ID</th>
                                        <th>Unit Price</th>
                                        <th style="text-align: center;">Quantity</th>
                                        <th style="text-align: right;">Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td class="d-flex align-center gap-3"  style="min-width: 270px;width: 270px;">
                                            <img style="width: 48px;height: 44px;border-radius: var(--radius-sm);"
                                                src="//timeaccess-store.com/cdn/shop/files/T165.807.11.031.00-a.jpg?v=1781357864&amp;width=1000"
                                                alt="Product Image"/>
                                            <div>
                                                <div class="text-left fw-medium">Seiko Prospex 'Zakynthos' Limited
                                                    Edition</div>
                                            </div>
                                        </td>
                                        <td>PROD-105</td>
                                        <td>TK 1200.00</td>
                                        <td style="text-align: center; font-weight: 600;">3</td>
                                        <td  style="text-align: right; font-weight: 600;">TK 3,600.00</td>
                                    </tr>
                                    <tr>
                                        <td class="d-flex align-center gap-3"  style="min-width: 270px;width: 270px;">
                                            <img style="width: 48px;height: 44px;border-radius: var(--radius-sm);"
                                                src="//timeaccess-store.com/cdn/shop/files/T165.807.11.031.00-a.jpg?v=1781357864&amp;width=1000"
                                                alt="Product Image"/>
                                            <div>
                                                <div  class="text-left fw-medium">Rado Florence Diamond Two-Tone</div>
                                            </div>
                                        </td>
                                        <td>PROD-105</td>
                                        <td>TK 1200.00</td>
                                        <td style="text-align: center;font-weight: 600;">2</td>
                                        <td  style="text-align: right; font-weight: 600;">TK 2,400.00</td>
                                    </tr>
                                    <tr>
                                        <td class="d-flex align-center gap-3"  style="min-width: 270px;width: 270px;">
                                            <img style="width: 48px;height: 44px;border-radius: var(--radius-sm);"
                                                src="https://timeaccess-store.com/cdn/shop/files/SPB473J1-G.jpg?v=1781940506&amp;width=1000"
                                                alt="Product Image"/>
                                            <div>
                                                <div  class="text-left fw-medium">Rado Florence Diamond Two-Tone</div>
                                            </div>
                                        </td>
                                        <td>PROD-105</td>
                                        <td>TK 1200.00</td>
                                        <td style="text-align: center;font-weight: 600;">2</td>
                                        <td  style="text-align: right; font-weight: 600;">TK 2,400.00</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <!-- Order Pricing Summary -->
                        <div class="summary-wrapper d-flex justify-end">
                            <table class="summary-table">
                                <tbody>
                                    <tr>
                                        <td class="text-primary" style="text-align: left;font-weight: 600;">Subtotal
                                        </td>
                                        <td class="text-primary" style="text-align: right;font-weight: 600;">TK
                                            6,000.00</td>
                                    </tr>
                                    <tr>
                                        <td class="text-primary" style="text-align: left;font-weight: 600;">Shipping
                                            &amp; Handling</td>
                                        <td class="text-primary" style="text-align: right;font-weight: 600;">TK 0.00
                                        </td>
                                    </tr>
                                    <tr class="total-row">
                                        <td class="text-primary"
                                            style="text-align: left;font-weight: 700;font-size: var(--fs-md);">Grand
                                            Total</td>
                                        <td class="text-primary"
                                            style="text-align: right;font-weight: 700;font-size: var(--fs-md);">TK
                                            6,000.00</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                    </div>
                </div>
            </div>
        </section>


            <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
        <script>
            document.getElementById('downloadInvoiceBtn').addEventListener('click', function () {
                const targetSection = document.querySelector('.order-details-card');
                const btnGroup = targetSection.querySelector('.btn-wraps');

                const originalText = this.innerHTML;
                this.innerText = "Generating Image...";
                this.disabled = true;

                if (btnGroup) {
                    btnGroup.style.display = 'none';
                }

                html2canvas(targetSection, {
                    scale: 2,
                    useCORS: true,
                    backgroundColor: '#f9f9f9'
                }).then(canvas => {
                    const imageURI = canvas.toDataURL('image/png');

                    const downloadLink = document.createElement('a');
                    downloadLink.href = imageURI;
                    downloadLink.download = 'Invoice_INV-2026-8942.png';

                    document.body.appendChild(downloadLink);
                    downloadLink.click();
                    document.body.removeChild(downloadLink);

                    if (btnGroup) {
                        btnGroup.style.display = 'flex';
                    }

                    this.innerHTML = originalText;
                    this.disabled = false;
                }).catch(error => {
                    console.error('Oops, something went wrong!', error);

                    if (btnGroup) {
                        btnGroup.style.display = 'flex';
                    }

                    this.innerHTML = originalText;
                    this.disabled = false;
                });
            });
        </script>

        </t>
    </template>
</odoo>