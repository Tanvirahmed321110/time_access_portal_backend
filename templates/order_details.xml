<odoo>
    <template id="order_details_page">
        <t t-call="time_access_portal.custom_layout">

            <link rel="stylesheet" href="/time_access_portal/static/src/css/cart-checkout.css?v=1"/>


            <!--===================================================================-->
            <!--================||  Order Details Section Here   ||=============== -->
            <!--===================================================================-->
            <section class="order-sec my-7">
                <div class="container">
                    <div id="order-details-section" style="max-width: 1080px; margin: 0 auto ;margin-top: 32px;">
                        <h2 class="page-title">Order Details</h2>

                        <div class="card mt-5 p-7 radius-xxl order-details-card">
                            <!-- Details Header Info -->
                            <div class="details-header flex-between">
                                <div>
                                    <h5 class="fw-bolder text-primary fs-md">Order ID:
                                        <t t-esc="order.name"/>
                                    </h5>
                                    <p class="mt-2 ">
                                        <span class="fw-bolder">Placed on:
                                            <span class="fw-normal"><t t-esc="order.date_order.strftime('%B %d, %Y at %I:%M %p') if order.date_order else ''"/></span>
                                        </span>
                                    </p>
                                </div>
                                <div class=" d-flex justify-end gap-4 flex-wrap btn-wraps gap-sm-3">
                                    <a href="/orders" class="btn btn-outline">Back To Orders</a>
                                    <button class="btn btn-primary" id="downloadInvoiceBtn">Download Invoice</button>
                                </div>
                            </div>

                            <!-- Shipping and Wholesaler Info Grid -->
                            <div class="grid-3 mt-7 gap-3 grid-sm-1" style="margin:48px 0">
                                <div class="info-box">
                                    <h5 class="text-primary mb-2 fw-bolder">Shipping Address</h5>
                                    <p>
                                        <span class="fw-medium"><t t-esc="request.env.company.name"/></span><br/>
                                        <t t-esc="request.env.company.street or 'N/A'"/>
                                    </p>
                                </div>
                                <div class="info-box">
                                    <h5 class="text-primary mb-2 fw-bolder">Payment Method</h5>
                                    <p>Bank Transfer<br/> <span class="fw-medium">Status:</span>
                                        <t t-if="order.invoice_ids">
                                            <span class="badge success">Paid</span>
                                        </t>
                                        <t t-else="">
                                            <span class="badge pending">Unpaid</span>
                                        </t>
                                    </p>
                                </div>
                                <div class="info-box">
                                    <h5 class="text-primary mb-2 fw-bold">Fulfillment Status</h5>
                                    <p><span class="fw-medium">Status:</span>
                                        <t t-if="order.state == 'sale'">
                                            <span class="badge pending">Processing</span>
                                        </t>
                                        <t t-elif="order.state == 'done'">
                                            <span class="badge success">Delivered</span>
                                        </t>
                                        <t t-elif="order.state == 'cancel'">
                                            <span class="badge cancel">Canceled</span>
                                        </t>
                                        <br/>
                                        <t t-if="delivery_date">
                                            Delivered Date: <span class="fw-medium"><t t-esc="delivery_date.strftime('%B %d, %Y')"/></span>
                                        </t>
                                        <t t-elif="order.state == 'done' and not delivery_date">
                                            Delivered Date: <span class="fw-medium"><t t-esc="order.write_date.strftime('%B %d, %Y')"/></span>
                                        </t>
                                        <t t-else="">
                                            <span class="fw-medium">Expected Delivery:</span>
                                             3 to 7 days
                                        </t>
                                    </p>
                                </div>
                            </div>

                            <!-- Ordered Items Table -->
                            <div class="table-responsive order-confrim mt-7 w-100-p">
                                <table class="manifest-table" style="width: 100%;">
                                    <thead>
                                        <tr>
                                            <th style="min-width: 200px;width: 200px;">Product Details</th>
                                            <th>Item ID</th>
                                            <th>Unit Price</th>
                                            <th style="text-align: center;">Quantity</th>
                                            <th style="text-align: right;">Total</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="order_lines" t-as="line">
                                            <tr>
                                                <td class="d-flex align-center gap-3"
                                                    style="min-width: 270px;width: 270px;">
                                                    <t t-if="line.product_id.image_128">
                                                        <img t-att-src="image_data_uri(line.product_id.image_128)"
                                                             style="width:48px; height:44px; border-radius:var(--radius-sm);"
                                                             alt="Product Image"/>
                                                    </t>
                                                    <t t-else="">
                                                        <img src="/web/static/img/placeholder.png"
                                                             style="width:48px; height:44px; border-radius:var(--radius-sm);"
                                                             alt="Product Image"/>
                                                    </t>
                                                    <div>
                                                        <div class="text-left fw-medium">
                                                            <t t-esc="line.product_id.name"/>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td>
                                                    <t t-esc="line.product_id.default_code or 'N/A'"/>
                                                </td>
                                                <td>TK
                                                    <t t-esc="'%.2f' % line.price_unit"/>
                                                </td>
                                                <td style="text-align:center; font-weight:600;">
                                                    <t t-esc="int(line.product_uom_qty)"/>
                                                </td>
                                                <td style="text-align:right; font-weight:600;">
                                                    TK
                                                    <t t-esc="'%.2f' % line.price_subtotal"/>
                                                </td>

                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>

                            <!-- Order Pricing Summary -->
                            <div class="summary-wrapper d-flex justify-end">
                                <table class="summary-table">
                                    <tbody>
                                        <tr>
                                            <td class="text-primary" style="text-align: left;font-weight: 600;">Subtotal
                                            </td>
                                            <td class="text-primary" style="text-align: right;font-weight: 600;">TK
                                                <t t-esc="'%.2f' % order.amount_untaxed"/>
                                            </td>
                                        </tr>
                                        <tr>
                                            <td class="text-primary" style="text-align: left;font-weight: 600;">Shipping
                                                &amp; Handling
                                            </td>
                                            <td class="text-primary" style="text-align: right;font-weight: 600;">TK 0.00
                                            </td>
                                        </tr>
                                        <tr class="total-row">
                                            <td class="text-primary"
                                                style="text-align: left;font-weight: 700;font-size: var(--fs-md);">Grand
                                                Total
                                            </td>
                                            <td class="text-primary"
                                                style="text-align:right; font-weight:700; font-size:var(--fs-md);">
                                                TK
                                                <t t-esc="'%.2f' % order.amount_total"/>
                                            </td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>

                        </div>
                    </div>
                </div>
            </section>


            <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
            <script>
                document.getElementById('downloadInvoiceBtn').addEventListener('click', function () {
                const targetSection = document.querySelector('.order-details-card');
                const btnGroup = targetSection.querySelector('.btn-wraps');

                const originalText = this.innerHTML;
                this.innerText = "Generating Image...";
                this.disabled = true;

                if (btnGroup) {
                btnGroup.style.display = 'none';
                }

                html2canvas(targetSection, {
                scale: 2,
                useCORS: true,
                backgroundColor: '#f9f9f9'
                }).then(canvas => {
                const imageURI = canvas.toDataURL('image/png');

                const downloadLink = document.createElement('a');
                downloadLink.href = imageURI;
                downloadLink.download = 'Invoice_INV-2026-8942.png';

                document.body.appendChild(downloadLink);
                downloadLink.click();
                document.body.removeChild(downloadLink);

                if (btnGroup) {
                btnGroup.style.display = 'flex';
                }

                this.innerHTML = originalText;
                this.disabled = false;
                }).catch(error => {
                console.error('Oops, something went wrong!', error);

                if (btnGroup) {
                btnGroup.style.display = 'flex';
                }

                this.innerHTML = originalText;
                this.disabled = false;
                });
                });
            </script>

        </t>
    </template>
</odoo>