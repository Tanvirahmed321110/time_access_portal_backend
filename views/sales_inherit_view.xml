<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Add to Carts Menu Action: only Add to Cart state -->
    <record id="action_add_to_carts" model="ir.actions.act_window">
        <field name="name">Add to Carts</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('state', '=', 'add_to_cart')]</field>
        <field name="context">{'default_state': 'add_to_cart'}</field>
    </record>


    <!-- Force Sales > Orders parent click to open Quotations menu_id active -->
    <record id="action_open_quotations_as_active_menu" model="ir.actions.act_url">
        <field name="name">Open Quotations</field>
        <field name="url"
               eval="'/web#action=%s&amp;menu_id=%s&amp;model=sale.order&amp;view_type=list' % (ref('sale.action_quotations_with_onboarding'), ref('sale.menu_sale_quotations'))"/>
        <field name="target">self</field>
    </record>

    <record id="sale.sale_order_menu" model="ir.ui.menu">
        <field name="action" eval="'ir.actions.act_url,%d' % ref('action_open_quotations_as_active_menu')"/>
    </record>

    <menuitem id="menu_add_to_carts"
              name="Add to Carts"
              parent="sale.sale_order_menu"
              action="action_add_to_carts"
              sequence="-15"
              groups="time_access_portal.group_b2b_management"/>

    <!-- Quotations Menu: hide Add to Cart orders -->
    <record id="sale.action_quotations_with_onboarding" model="ir.actions.act_window">
        <field name="domain">[('state', 'in', ['draft', 'sent'])]</field>
    </record>

    <!-- Orders Menu: hide Add to Cart orders -->
    <record id="sale.action_orders" model="ir.actions.act_window">
        <field name="domain">[('state', 'not in', ['draft', 'sent', 'cancel', 'add_to_cart'])]</field>
    </record>

    <!-- Hide Add to Cart from sale order statusbar -->
    <record id="view_order_form_inherit_add_to_cart_state" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.add.to.cart.state</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="priority">100</field>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='state']" position="attributes">
                <attribute name="statusbar_visible">draft,sent,sale</attribute>
            </xpath>

        </field>
    </record>

    <!-- Add B2B Sale field below Payment Terms -->
    <record id="view_order_form_inherit_b2b_sale_field" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.b2b.sale.field</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="priority">110</field>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="b2b_sale" readonly="1"/>
            </xpath>

        </field>
    </record>

