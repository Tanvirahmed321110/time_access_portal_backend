<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ==================== Project Tree/List View ==================== -->
    <record id="view_project_tree_inherit" model="ir.ui.view">
        <field name="name">project.project.tree.inherit</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project"/>
        <field name="arch" type="xml">

            <!--  For Order   -->
            <xpath expr="//list" position="attributes">
                <attribute name="default_order">create_date desc</attribute>
            </xpath>


            <!--  Remove Partner ID  -->
            <xpath expr="//list/field[@name='partner_id']" position="replace"></xpath>


            <xpath expr="//list/field[@name='user_id']" position="after">
                <field name="custom_priority" widget="badge" optional="show"/>
                <field name="custom_status" widget="badge" optional="show"/>
            </xpath>
        </field>
    </record>


    <!-- ==================== Project Form View ==================== -->
    <record id="view_project_form_inherit" model="ir.ui.view">
        <field name="name">project.project.form.inherit</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='tag_ids']" position="after">
                <field name="custom_priority" widget="selection"/>
                <field name="custom_status" widget="selection"/>
            </xpath>

             <!--  Label Field Hide  -->
            <xpath expr="//field[@name='label_tasks']" position="attributes">
                 <attribute name="invisible">1</attribute>
            </xpath>

            <!--  Change Name Placeholder  -->
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="placeholder">Project Name</attribute>
            </xpath>

            <!-- add assignee members -->
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="assigned_user_ids" widget="many2many_tags"/>
            </xpath>

             <!-- ✅ Description er por new page add -->
            <xpath expr="//page[@name='description']" position="after">
                <page name="Usefull Links" string="Usefull Links">
                        <group>
                            <field name="github_link"/>
                            <field name="dev_link"/>
                            <field name="live_link"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>


    <!-- ==================== Project Form View Inherit Project Invoice ==================== -->
    <record id="view_project_invoice_form_inherit" model="ir.ui.view">
        <field name="name">project.project.invoice.form.inherit</field>
        <field name="model">project.project</field>
        <!-- inherit hr_timesheet form -->
        <field name="inherit_id" ref="hr_timesheet.project_invoice_form"/>

        <field name="arch" type="xml">

            <!-- add deadline field -->
            <xpath expr="//field[@name='allocated_hours']" position="before">
                <field name="date" string="Project Deadline"/>
            </xpath>

            <!-- add remaining_days field -->
            <xpath expr="//field[@name='allocated_hours']" position="after">
                <field name="remaining_days"/>
            </xpath>
        </field>
    </record>
</odoo>