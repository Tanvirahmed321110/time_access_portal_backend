<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ==================== Product Template Form View ==================== -->
    <record id="view_product_form_inherit" model="ir.ui.view">
        <field name="name">product.template.form.inherit.b2b.portal</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='purchase_ok']/.." position="after">
                <span class="d-inline-block">
                    <field name="is_b2b_portal"/>
                    <label for="is_b2b_portal"/>
                </span>
            </xpath>

            <xpath expr="//field[@name='categ_id']" position="before">
                <field name="b2b_price"
                       string="B2B Price"
                       widget="monetary"
                       groups="time_access_portal.group_b2b_management"
                       class="oe_inline"/>
            </xpath>

            <xpath expr="//field[@name='b2b_price']" position="after">
                <field name="b2b_category" string="B2B Category" class="oe_inline"/>
            </xpath>
            <xpath expr="//field[@name='b2b_category']" position="after">
                <field name="b2b_qty" string="B2B Category" class="oe_inline"/>
            </xpath>
        </field>
    </record>

</odoo>